@{
    ViewData["Title"] = "Access Denied";
}

<section class="mx-auto max-w-xl">
    <div class="panel-card text-center">
        <h1 class="font-display text-3xl font-semibold text-slate-900 dark:text-slate-100">Access Denied</h1>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">You do not have permission to access this page.</p>
        <a asp-controller="Dashboard" asp-action="Index" class="mt-5 inline-flex rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white dark:bg-slate-100 dark:text-slate-900">
            Back to Dashboard
        </a>
    </div>
</section>
